# ============================================
# 视频智能体 - 环境变量配置
# 复制此文件为 .env.local 并填入实际值
# ============================================

# ---- LLM（文案润色、标题生成等）----
# 也用于 Whisper 语音转文字（同一个 Key）
LLM_API_KEY=sk-your-openai-api-key
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# ---- TTS（语音合成）----
TTS_API_KEY=sk-your-openai-api-key
TTS_MODEL=tts-1
TTS_BASE_URL=https://api.openai.com/v1

# ---- 数字人（D-ID 等）----
AVATAR_API_KEY=your-did-api-key
AVATAR_BASE_URL=https://api.d-id.com

# ---- 视频处理（ffmpeg 路径，已安装则自动检测）----
# FFMPEG_PATH=ffmpeg

# ---- 多平台发布（按需配置）----
# DOUYIN_CLIENT_ID=
# DOUYIN_CLIENT_SECRET=
